{
  "name": "butterchurn",
  "type": "module",
  "version": "3.0.0-beta.5",
  "description": "Butterchurn is a WebGL implementation of the Milkdrop Visualizer",
  "author": "Jordan Berg <jordannealberg@gmail.com>",
  "license": "MIT",
  "homepage": "https://butterchurnviz.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jberg/butterchurn.git"
  },
  "keywords": [
    "music visualization",
    "visualizer",
    "webgl",
    "webaudio"
  ],
  "main": "dist/butterchurn.js",
  "module": "dist/butterchurn.js",
  "unpkg": "dist/butterchurn.js",
  "files": [
    "dist/butterchurn.js",
    "dist/butterchurn.min.js",
    "dist/isSupported.min.js"
  ],
  "scripts": {
    "build": "cross-env NODE_ENV=production vite build",
    "build:dev": "cross-env NODE_ENV=development vite build",
    "lint": "eslint \"**/*.{ts,js}\"",
    "lint:fix": "eslint \"**/*.{ts,js}\" --fix",
    "test": "node --test test/**/*.test.js",
    "test:visual": "node --test test/visual/regression.test.js",
    "test:visual:update": "cross-env UPDATE_SNAPSHOTS=true node --test test/visual/regression.test.js",
    "test:visual:watch": "node --test --watch test/visual/regression.test.js",
    "test:visual:local": "npm run build:dev && npm run test:visual",
    "test:visual:view": "start test/visual/__image_snapshots__/__diff_output__"
  },
  "dependencies": {
    "@assemblyscript/loader": "^0.17.11",
    "ecma-proposal-math-extensions": "0.0.2",
    "eel-wasm": "^0.0.16"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "assemblyscript": "^0.17.11",
    "butterchurn-presets": "3.0.0-beta.4",
    "butterchurn-presets-js": "npm:butterchurn-presets@^2.4.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "puppeteer": "^24.12.1",
    "vite": "^7.3.1"
  },
  "browserslist": "supports audio-api and supports webgl2 and last 3 years"
}
