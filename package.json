{
  "name": "butterchurn-typed",
  "type": "module",
  "version": "1.0.0",
  "description": "Butterchurn, but typed.",
  "author": "Jordan Berg <jordannealberg@gmail.com>",
  "license": "MIT",
  "homepage": "https://butterchurnviz.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uvmain/butterchurn-typed.git"
  },
  "keywords": [
    "music visualization",
    "visualizer",
    "webgl",
    "webaudio"
  ],
  "exports": {
    ".": {
      "types": "./dist/butterchurn.d.ts",
      "import": "./dist/butterchurn.js"
    }
  },
  "main": "./dist/butterchurn.js",
  "module": "./dist/butterchurn.js",
  "types": "./dist/butterchurn.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf --glob dist \"test/visual/__image_snapshots__/__diff_output__\" \"test/visual/__image_snapshots__/*-snap.png\"",
    "build": "tsc && vite build",
    "lint": "eslint \"**/*.{ts,js}\"",
    "lint:fix": "eslint \"**/*.{ts,js}\" --fix",
    "test": "node --test test/**/*.test.js",
    "test:visual": "node --test test/visual/regression.test.js",
    "test:visual:update": "cross-env UPDATE_SNAPSHOTS=true node --test test/visual/regression.test.js",
    "test:visual:watch": "node --test --watch test/visual/regression.test.js",
    "test:visual:local": "npm run build && npm run test:visual",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assemblyscript/loader": "^0.28.9",
    "ecma-proposal-math-extensions": "0.0.2",
    "eel-wasm": "^0.0.17"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@types/node": "^25.3.3",
    "assemblyscript": "^0.28.9",
    "butterchurn-presets": "3.0.0-beta.4",
    "butterchurn-presets-js": "npm:butterchurn-presets@^2.4.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.2",
    "puppeteer": "^24.37.5",
    "rimraf": "^6.1.3",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "browserslist": "supports audio-api and supports webgl2 and last 3 years",
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
